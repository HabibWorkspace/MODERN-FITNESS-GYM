# ============================================
# FitCore Backend Environment Variables
# ============================================

# ============================================
# DATABASE CONFIGURATION (Supabase)
# ============================================
# Get this from: Supabase Dashboard → Settings → Database → Connection String (URI)
# Format: postgresql://postgres.xxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_ENV=development
# For production, set to: production

# Generate secure keys using: python generate_keys.py
# Or use: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ============================================
# JWT CONFIGURATION
# ============================================
# Token expiration in seconds (86400 = 24 hours)
JWT_ACCESS_TOKEN_EXPIRES=86400

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# For Gmail, you MUST use an App Password (not your regular password)
# Setup: https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Local development
FRONTEND_URL=http://localhost:5173
# Production (update after Vercel deployment)
# FRONTEND_URL=https://your-app.vercel.app

# ============================================
# GYM CONFIGURATION (Optional)
# ============================================
# Used for geofencing features
GYM_LATITUDE=40.7128
GYM_LONGITUDE=-74.0060
GEOFENCE_RADIUS_METERS=100

# ============================================
# BIOMETRIC DEVICE CONFIGURATION
# ============================================
# IP address of your ZKTeco biometric attendance device
BIOMETRIC_DEVICE_IP=192.168.100.35
BIOMETRIC_DEVICE_PORT=4370

# ============================================
# PUSHER CONFIGURATION (Real-time Notifications)
# ============================================
# Get credentials from: https://dashboard.pusher.com
PUSHER_APP_ID=your-pusher-app-id
PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=mt1

# ============================================
# EXTERNAL APIs (Optional)
# ============================================
# Nutrition tracking features (not currently used)
NUTRITIONIX_API_KEY=
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real values to Git
# 2. Copy this file to .env and fill in your values
# 3. For production, set these in Vercel environment variables
# 4. Generate secure keys using: python generate_keys.py

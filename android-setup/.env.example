# Android Device Sync Configuration
# Copy this file to .env and update with your actual values

# PythonAnywhere Configuration
PYTHONANYWHERE_URL=https://habibworkspace.pythonanywhere.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# Biometric Device Configuration
# This should be the IP address of your iFace950 ZKT device on the local network
# Check the device: Menu → Comm → TCP/IP to find the correct IP
BIOMETRIC_DEVICE_IP=192.168.0.201
BIOMETRIC_DEVICE_PORT=4370

# Sync Configuration
# How often to check for new attendance logs (in seconds)
SYNC_INTERVAL=3

# Pusher Configuration (Optional - for real-time notifications)
# These are already configured on your backend, but included here for reference
PUSHER_APP_ID=2142303
PUSHER_KEY=8f96a097d2f6d11c1a34
PUSHER_SECRET=97a957c4a520fe63a10e
PUSHER_CLUSTER=mt1
